{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Introduction: ビルド",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build-introduction.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Introduction: PDFを再表示",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/refresh-pdf.sh",
      "args": ["${workspaceFolder}/Introduction/summer_2026_introduction.pdf"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Introduction: ビルドしてPDFを更新",
      "dependsOn": ["Introduction: ビルド", "Introduction: PDFを再表示"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Introduction: PDFだけ開く",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/open-introduction-pdf.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Introduction: PDFをプレビューで開く（ビルド＋表示）",
      "dependsOn": ["Introduction: ビルド", "Introduction: PDFだけ開く"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Introduction: 外部PDFを開いてリアルタイム更新",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/watch-introduction.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "PDFを外部で開く（編集中のTeXと同名）",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/refresh-pdf.sh",
      "args": ["${fileDirname}/${fileBasenameNoExtension}.pdf"],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
