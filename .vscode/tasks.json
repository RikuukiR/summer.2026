{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Introduction: ビルド",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build-introduction.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Introduction: PDFだけ開く",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/open-introduction-pdf.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Introduction: PDFをプレビューで開く（ビルド＋表示）",
      "dependsOn": ["Introduction: ビルド", "Introduction: PDFだけ開く"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Introduction: 外部PDFを開いてリアルタイム更新",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/watch-introduction.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false
      },
      "problemMatcher": [],
      "runOptions": {
        "reevaluateOnRerun": false
      }
    },
    {
      "label": "PDFを外部で開く（編集中のTeXと同名）",
      "type": "shell",
      "command": "/usr/bin/open -a Preview \"${fileDirname}/${fileBasenameNoExtension}.pdf\"",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
