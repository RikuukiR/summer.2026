{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Introduction: 外部PDFを開いてリアルタイム更新",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/watch-introduction.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "Introduction: PDFを外部で開く（ビルドしてから）",
      "type": "shell",
      "command": "/bin/bash",
      "args": [
        "-lc",
        "${workspaceFolder}/scripts/build-introduction.sh && /usr/bin/open ${workspaceFolder}/Introduction/summer_2026_introduction.pdf"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "PDFを外部で開く（編集中のTeXと同名）",
      "type": "shell",
      "command": "/usr/bin/open",
      "args": ["${fileDirname}/${fileBasenameNoExtension}.pdf"],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
