{
  "latex-workshop.latex.recipe.default": "upLaTeX",
  "latex-workshop.latex.recipes": [
    {
      "name": "pLaTeX",
      "tools": [
        "platex",
        "platex",
        "dvipdfmx",
        "open-pdf-external"
      ]
    },
    {
      "name": "upLaTeX",
      "tools": [
        "uplatex",
        "uplatex",
        "dvipdfmx",
        "open-pdf-external"
      ]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "platex",
      "command": "/Library/TeX/texbin/platex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-kanji=utf8",
        "%DOC%"
      ]
    },
    {
      "name": "uplatex",
      "command": "/Library/TeX/texbin/uplatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-kanji=utf8",
        "%DOC%"
      ]
    },
    {
      "name": "dvipdfmx",
      "command": "/Library/TeX/texbin/dvipdfmx",
      "args": [
        "%DOCFILE%.dvi"
      ]
    },
    {
      "name": "open-pdf-external",
      "command": "/usr/bin/open",
      "args": [
        "%DOC%.pdf"
      ]
    }
  ],
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.autoBuild.interval": 1000,
  "latex-workshop.latex.watch.pdf.delay": 400,
  "latex-workshop.view.pdf.viewer": "external",
  "latex-workshop.view.pdf.ref.viewer": "external",
  "latex-workshop.view.autoFocus.enabled": false,
  "latex-workshop.view.pdf.external.viewer.command": "/usr/bin/open",
  "latex-workshop.view.pdf.external.viewer.args": ["%PDF%"],
  "latex-workshop.synctex.afterBuild.enabled": false,
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.ist",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
    "*.dvi",
    "*.synctex.gz"
  ]
}
